<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" 
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.investment.analyzer.market_analyzer.domain.repository.market.MarketStatisticsMapper">
    
    <!-- 목록 조회 -->
    <select id="findAllMarket" resultType="MarketStatistics">
        SELECT ID
             , STAT_DATE
             , STAT_TIME
             , MARKET_NAME
             , DESCRIPTION
             , INDEX_VALUE
             , CHANGE_PERCENTAGE
             , CHANGE_DIRECTION
             , CREATED_AT
             , UPDATED_AT
          FROM MARKET_STATISTICS
        WHERE 1=1
        <!-- 동적 쿼리 조건 -->
    </select>
    
    <select id="findAllMarketCnt" resultType="int">
        SELECT count(*)
          FROM MARKET_STATISTICS
        WHERE 1=1
        <!-- 동적 쿼리 조건 -->
    </select>

</mapper>