<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.investment.stockadvisor.domain.repository.divergence.StockSectorMapper">

    <select id="findSectorCodeByStockCd" resultType="string">
        SELECT sector_code
        FROM stock_sector
        WHERE stock_cd = #{stockCd}
        LIMIT 1
    </select>

    <select id="findStockCdsBySectorCode" resultType="string">
        SELECT stock_cd
        FROM stock_sector
        WHERE sector_code = #{sectorCode}
    </select>

</mapper>
